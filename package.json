{
  "name": "generative-semantic-ui",
  "private": true,
  "version": "0.0.0",
  "description": "It's like HTML for AI agents.",
  "workspaces": [
    "packages/*",
    "playground",
    "apps/*"
  ],
  "scripts": {
    "build:core": "npm run build --workspace=@generative-semantic-ui/core",
    "build:html": "npm run build --workspace=@generative-semantic-ui/html",
    "build:shadcn": "npm run build --workspace=@generative-semantic-ui/shadcn",
    "build:packages": "npm run build:core && npm run build:html && npm run build:shadcn",
    "dev:playground": "npm run dev --workspace=playground",
    "build:playground": "npm run build --workspace=playground",
    "dev:portfolio": "npm run dev --workspace=portfolio",
    "build:portfolio": "npm run build --workspace=portfolio"
  }
}
