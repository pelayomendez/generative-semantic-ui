{
  "name": "@semantic-html-ai/core",
  "version": "0.1.0",
  "description": "Semantic HTML for AI — a closed JSX vocabulary for LLM-generated UI, compiled to your component library of choice.",
  "keywords": [
    "ai",
    "llm",
    "ui",
    "jsx",
    "generative-ui",
    "react",
    "dsl",
    "anthropic",
    "openai"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "@babel/parser": "^7.29.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.7",
    "react": "^19.2.3",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  }
}
